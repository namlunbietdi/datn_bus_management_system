PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/bus_monitoring
JWT_SECRET=change_me

MQTT_URL=mqtts://xxxxxxxx.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=your_username
MQTT_PASSWORD=your_password
MQTT_CLIENT_ID=bus-monitor-local

# Alternative if you do not use MQTT_URL:
# MQTT_HOST=xxxxxxxx.s1.eu.hivemq.cloud
# MQTT_PORT=8883
# MQTT_PROTOCOL=mqtts

MQTT_TOPIC_TELEMETRY=bus/+/telemetry
MQTT_TOPIC_GPS=bus/+/gps
MQTT_TOPIC_EVENT=bus/+/event
MQTT_TOPIC_STATUS=bus/+/status
MQTT_TOPIC_COMMAND_PREFIX=bus

EXPORT_DIR=exports
PUBLIC_BASE_URL=http://localhost:3000
# Optional. If set, ESP32 must send x-device-token or Bearer token to /api/runtime/*.
DEVICE_UPDATE_TOKEN=
# Optional. If set, /api/esp/routes/:routeCode.json requires ?token=...
ESP_ROUTE_DOWNLOAD_TOKEN=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Admin
